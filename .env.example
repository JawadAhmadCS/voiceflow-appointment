# Copy to `.env` / `.env.local` (never commit real secrets).

# Production / Vercel: use Postgres (file cipher is disabled on Vercel).
# Neon: https://console.neon.tech → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Local-only: AES-256-GCM encrypted file at data/bookings.enc (ignored by git).
# Ignored when DATABASE_URL is set, or when VERCEL=1.
# Use a long random passphrase (8+ characters).
# BOOKINGS_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Optional: custom path for the encrypted file (default: data/bookings.enc)
# BOOKINGS_FILE_PATH=data/bookings.enc
